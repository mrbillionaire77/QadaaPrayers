{
  "expo": {
    "name": "قضاء الصلوات",
    "slug": "qadaa-prayers",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "onspaceapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#1F4A3A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.qadaaprayers.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/mosque-icon.png",
      "name": "قضاء الصلوات",
      "shortName": "قضاء الصلوات",
      "description": "تطبيق لتتبع الصلوات الفائتة وقضائها",
      "themeColor": "#1F4A3A",
      "backgroundColor": "#F5F0E6",
      "display": "standalone",
      "orientation": "portrait",
      "lang": "ar",
      "dir": "rtl"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
